---
import db from "../lib/db";

const projects = db.prepare(`
  SELECT id, title, slug, subtitle, main_image 
  FROM cases 
  ORDER BY created_at DESC 
  LIMIT 6
`).all();
---

<section class="gallery" id="works">
  <div class="gallery__container">
    <h2 class="gallery__title">Наши работы</h2>
    
    <div class="gallery__grid">
      {projects.map((project, index) => (
        <a href={`/case?slug=${project.slug}`} class={`gallery__item ${[1, 3, 5].includes(index) ? 'gallery__item--tall' : ''}`}>
          <img src={project.main_image} alt={project.title} />
          <div class="gallery__overlay">
            <h3 class="gallery__overlay-project">{project.title}</h3>
            <p class="gallery__overlay-desc">{project.subtitle}</p>
            <div class="gallery__overlay-link">Посмотреть кейс <span>→</span></div>
          </div>
        </a>
      ))}
    </div>
    
    <div class="gallery__footer">
        <a href="/cases" class="gallery__load-more">Все проекты</a>
    </div>
  </div>
</section>

<style lang="scss">
.gallery {
  padding: var(--space-20) 0;
  background-color: var(--color-white);

  &__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }

  &__title {
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin-bottom: var(--space-12);
    text-align: center;

    @media (min-width: 768px) {
      font-size: var(--text-5xl);
    }
  }

  &__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    grid-auto-rows: minmax(100px, auto);

    @media (min-width: 768px) {
        grid-template-columns: repeat(2, 1fr);
    }

    @media (min-width: 1024px) {
      grid-template-columns: repeat(3, 384px);
      grid-template-rows: repeat(3, 287px);
      justify-content: center;
    }
  }

  &__item {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    cursor: pointer;
    display: block; // Заменили div на a, нужно свойство
    text-decoration: none;
    
    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--transition-base);
    }

    &--tall {
        @media (min-width: 1024px) {
            grid-row: span 2;
        }
    }

    // Позиционирование элементов в сетке для 6 объектов
    @media (min-width: 1024px) {
        &:nth-child(1) { grid-column: 1; grid-row: 1; }
        &:nth-child(2) { grid-column: 2; grid-row: 1 / 3; }
        &:nth-child(3) { grid-column: 3; grid-row: 1; }
        &:nth-child(4) { grid-column: 1; grid-row: 2 / 4; }
        &:nth-child(5) { grid-column: 2; grid-row: 3; }
        &:nth-child(6) { grid-column: 3; grid-row: 2 / 4; }
    }

    &:hover {
        img {
            transform: scale(1.1);
        }
        .gallery__overlay {
            opacity: 1;
            visibility: visible;
            pointer-events: auto;
        }
    }
  }

  &__overlay {
    position: absolute;
    inset: 0;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    color: white;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: all var(--transition-base);
    
    &-project {
      font-size: 20px;
      font-weight: var(--font-bold);
      margin-bottom: 24px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    &-desc {
      font-size: 16px;
      line-height: 1.4;
      opacity: 0.9;
      margin-bottom: 24px;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    &-link {
        font-size: 16px;
        font-weight: var(--font-medium);
        color: white;
        text-decoration: underline;
        text-underline-offset: 4px;
        margin-top: auto;
        
        span {
            margin-left: 4px;
        }
    }
  }

  &__footer {
      margin-top: 48px;
      display: flex;
      justify-content: center;
  }

  &__load-more {
      padding: 16px 32px;
      background-color: white;
      border: 1px solid #E5E7EB;
      border-radius: var(--radius-full);
      font-size: 16px;
      font-weight: var(--font-bold);
      color: #111111;
      text-decoration: none; // Для <a>
      cursor: pointer;
      transition: all var(--transition-fast);

      &:hover {
          background-color: #F9FAFB;
          border-color: #D1D5DB;
      }
  }
}
</style>
