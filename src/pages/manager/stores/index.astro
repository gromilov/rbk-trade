---
export const prerender = false;
import ManagerLayout from "../../../layouts/ManagerLayout.astro";
import db from "../../../lib/db";

const stores = db.prepare('SELECT * FROM stores ORDER BY id DESC').all();
---

<ManagerLayout title="Шоу-румы">
  <div class="manager-header">
    <div class="manager-header__left">
      <h2 class="manager-header__title">Ваши шоу-румы</h2>
      <p class="manager-header__subtitle">Управление точками продаж и магазинами</p>
    </div>
    <a href="/manager/stores/add" class="btn-primary">+ Добавить магазин</a>
  </div>

  <div class="stores-grid">
    {stores.map(store => (
      <div class="store-item">
        <div class="store-item__img">
          {store.image_path ? (
            <img src={store.image_path} alt="" />
          ) : (
            <div class="img-placeholder">🖼️</div>
          )}
        </div>
        <div class="store-item__info">
          <h3 class="store-item__title">{store.title}</h3>
          <p class="store-item__address">{store.address}</p>
          <div class="store-item__actions">
            <a href={`/manager/stores/edit?id=${store.id}`} class="btn-edit">Изменить</a>
            <button 
              class="btn-del" 
              onclick={`if(confirm('Удалить этот шоу-рум?')) window.location.href='/manager/stores/edit?delete=${store.id}'`}
            >
              Удалить
            </button>
          </div>
        </div>
      </div>
    ))}
  </div>
</ManagerLayout>

<style lang="scss">
  .manager-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
    gap: 16px;

    @media (max-width: 640px) {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 24px;
    }

    &__title {
      font-size: clamp(24px, 5vw, 32px);
      font-weight: 800;
      color: #111;
      margin-bottom: 4px;
    }

    &__subtitle {
      color: #999;
      font-size: 14px;
    }

    .btn-primary {
      @media (max-width: 640px) { width: 100%; }
    }
  }

  .stores-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;

    @media (min-width: 768px) {
      gap: 24px;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    }
  }

  .store-item {
    background: white;
    border-radius: 24px; // Slightly smaller radius on mobile
    border: 1px solid rgba(0,0,0,0.05);
    overflow: hidden;
    transition: transform 0.3s ease;

    @media (min-width: 1024px) {
      border-radius: 32px;
    }

    &:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    }

    &__img {
      aspect-ratio: 16/9; // Fixed ratio for consistency
      background: #F6F6F6;
      img { width: 100%; height: 100%; object-fit: cover; }
      .img-placeholder {
        height: 100%; display: flex; align-items: center; justify-content: center; font-size: 32px;
      }
    }

    &__info {
      padding: 20px;
      @media (min-width: 1024px) { padding: 24px; }
    }

    &__title {
      font-size: 18px;
      font-weight: 800;
      margin-bottom: 6px;
    }

    &__address {
      font-size: 13px;
      color: #666;
      margin-bottom: 20px;
      min-height: 36px;
    }

    &__actions {
      display: flex;
      gap: 10px;
    }

    .btn-edit {
      flex: 1;
      text-align: center;
      background: #DE6D20;
      color: white;
      text-decoration: none;
      padding: 12px;
      border-radius: 12px;
      font-weight: 700;
      font-size: 14px;
    }

    .btn-del {
      padding: 12px;
      background: #F6F6F6;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      font-weight: 700;
      color: #EF4444;
    }
  }
</style>
