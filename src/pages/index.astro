---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import CategoryBanners from "../components/CategoryBanners.astro";
import Stores from "../components/Stores.astro";
import BannerNew from "../components/BannerNew.astro";
import Gallery from "../components/Gallery.astro";
import Advantages from "../components/Advantages.astro";
import Reasons from "../components/Reasons.astro";
import FAQ from "../components/FAQ.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import Modal from "../components/UI/Modal.astro";
import Form from "../components/Form.astro";

---

<Layout title="РБК Трейд | Дизайнерские радиаторы в Казани">
  <div class="max-w-[100%] overflow-x-hidden relative">
    <Header />
    
    <!-- 6.1) Главный экран -->
    <Hero
      title="Дизайнерские радиаторы для любых помещений"
      text="Профессиональный подбор и поставка радиаторов от ведущих производителей"
      buttonText="Обсудить проект"
      bgImage="/images/overlay.png"
    />

    <!-- 6.2) Категории -->
    <CategoryBanners />

    <!-- 6.3) Магазины -->
    <Stores />

    <!-- 6.4) Баннер -->
    <BannerNew 
      title="Затрудняетесь с выбором?<br/> Наши эксперты помогут"
      bgColor="#111111"
      imagePosition="full"
      bgImage="/images/baner_4_.png"
      showSocial={true}
    />

    <!-- 6.5) Наши работы (Gallery) -->
    <Gallery />

    <!-- 6.6) Наши преимущества -->
    <Advantages />

    <!-- 6.7) Наши партнеры -->
    <Reasons
      variant="manufacturers"
      title="Работаем с лучшими производителями радиаторов"
    />

    <!-- 6.8) Вопросы-ответы -->
    <FAQ />

    <!-- 6.9) Форма ОС -->
    <Contact title="Рассчитаем ваш проект за 1 день" />

    <Footer />
    
    <Modal id="formModal">
      <Form />
    </Modal>
  </div>
</Layout>
