---
import Button from "./UI/Button.astro";

const {
  title = "Дизайнерам интерьеров в Казани и по Татарстану",
  subtitle = "С нами выгодно — эксклюзивные скидки для ваших клиентов и профессиональная поддержка на всех этапах проектирования.",
  items = [
    {
      text: "Индивидуальная система лояльности",
      icon: "/images/icons/design/Group 1171277575.svg",
    },
    {
      text: "Полная техническая поддержка проектов",
      icon: "/images/icons/design/Group 1171277576.svg",
    },
    {
      text: "Предоставление каталогов и образцов",
      icon: "/images/icons/design/Group 1171277576-1.svg",
    },
    {
      text: "Совместное продвижение проектов",
      icon: "/images/icons/design/Group-1171277576-2.svg",
    },
  ],
  buttonText = "ПОЛУЧИТЬ СПЕЦПРЕДЛОЖЕНИЕ",
} = Astro.props;
---

<section class="designers" id="designers">
  <div class="designers__container">
    <div class="designers__header">
      <h2 class="designers__title" set:html={title} />
      <p class="designers__subtitle" set:html={subtitle} />
    </div>

    <div class="designers__grid">
      {
        items.map((item) => (
          <div class="designers__item">
            <div class="designers__icon">
              <img src={item.icon} alt={item.text.substring(0, 10)} />
            </div>
            <p class="designers__text" set:html={item.text} />
          </div>
        ))
      }
    </div>

    <div class="designers__footer">
      <Button className="open-form" variant="dark">{buttonText}</Button>
    </div>
  </div>
</section>

<style lang="scss">
  .designers {
    padding: var(--space-20) 0;
    background-color: white;

    &__container {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--space-4);
      text-align: center;
    }

    &__header {
      max-width: 800px;
      margin: 0 auto var(--space-16);
    }

    &__title {
      font-size: var(--text-4xl);
      font-weight: var(--font-bold);
      color: #292524;
      margin-bottom: var(--space-6);

      @media (min-width: 768px) {
        font-size: var(--text-5xl);
      }
    }

    &__subtitle {
      font-size: var(--text-lg);
      color: #292524;
      opacity: 0.7;
      line-height: 1.5;
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(1, 1fr);
      gap: var(--space-6);
      margin-bottom: var(--space-16);

      @media (min-width: 640px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (min-width: 1024px) {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    &__item {
      background-color: #f6f6f6;
      padding: var(--space-10);
      border-radius: var(--radius-2xl);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-6);
      transition: transform var(--transition-base);

      &:hover {
        transform: translateY(-8px);
      }
    }

    &__icon {
      width: 64px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: center;

      img {
        width: 100%;
        height: 100%;
      }
    }

    &__text {
      font-size: var(--text-base);
      font-weight: var(--font-medium);
      color: var(--color-dark);
      line-height: 1.4;
    }

    &__footer {
      display: flex;
      justify-content: center;
    }
  }
</style>
