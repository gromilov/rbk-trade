---
import db from "../lib/db";
import Button from "./UI/Button.astro";

const casesItems = db.prepare(`
  SELECT c.*, t.name as type_label, 
  (SELECT GROUP_CONCAT(m.name) FROM case_manufacturers cm JOIN manufacturers m ON cm.manufacturer_id = m.id WHERE cm.case_id = c.id) as manufacturer_labels
  FROM cases c
  LEFT JOIN types t ON c.type_id = t.id
  ORDER BY c.created_at DESC
  LIMIT 4
`).all();

const { title = "Наши реализованные проекты" } = Astro.props;
---

<section class="cases-section">
  <div class="cases-section__container">
    <h2 class="cases-title">{title}</h2>
    <div class="cases-grid">
      {casesItems.map((item: any) => (
        <a href={`/case?slug=${item.slug}`} class="case-card-home">
          <div class="case-card-home__image-wrapper">
            <img src={item.main_image} alt={item.title} class="case-card-home__image" />
          </div>
          <div class="case-card-home__content">
            <div class="case-card-home__type">{item.type_label}</div>
            <h3 class="case-card-home__title">{item.title}</h3>
            <div class="case-card-home__tags">
              {item.manufacturer_labels && item.manufacturer_labels.split(',').map((tag: string) => (
                <span class="case-card-home__tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
    <div class="cases-button-container">
      <Button href="/cases" variant="dark">
        СМОТРЕТЬ ВСЕ ПРОЕКТЫ
      </Button>
    </div>
  </div>
</section>

<style lang="scss">
.cases-section {
  padding: 80px 0;
  background-color: #fff;
  
  &__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }
}

.cases-title {
  font-size: clamp(32px, 5vw, 64px);
  text-align: center;
  margin-bottom: 60px;
  font-weight: 700;
  color: #111111;
  line-height: 1.1;
}

.cases-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  
  @media (min-width: 768px) {
    grid-template-columns: 1fr 1fr;
  }
}

.case-card-home {
  background-color: #f6f6f6;
  border-radius: 24px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.3s ease;
  text-decoration: none;
  height: 100%;
  
  &:hover {
    transform: translateY(-8px);
  }

  &__image-wrapper {
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  &__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  &:hover &__image {
    transform: scale(1.05);
  }

  &__content {
    padding: 32px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  &__type {
    font-size: 14px;
    font-weight: 600;
    color: #DE6D20;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  &__title {
    font-size: 24px;
    font-weight: 700;
    color: #111111;
    margin-bottom: 20px;
    line-height: 1.3;
  }

  &__tags {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  &__tag {
    font-size: 12px;
    background: rgba(17, 17, 17, 0.05);
    padding: 6px 12px;
    border-radius: 100px;
    color: #525152;
    font-weight: 500;
  }
}

.cases-button-container {
  margin-top: 60px;
  display: flex;
  justify-content: center;
}
</style>