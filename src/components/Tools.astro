---
// src/components/toolsList.astro

const tools = [
  { src: "/images/tools/Django.png", name: "Django", url: "#" },
  { src: "/images/tools/Elasticsearch.png", name: "Elasticsearch", url: "#" },
  { src: "/images/tools/ELKStack.png", name: "ELK Stack", url: "#" },
  { src: "/images/tools/LangChain.png", name: "LangChain", url: "#" },
  { src: "/images/tools/PostgreSQL.png", name: "PostgreSQL", url: "#" },
  { src: "/images/tools/Prometheus.png", name: "Prometheus", url: "#" },
  { src: "/images/tools/Python.png", name: "Python", url: "#" },
  { src: "/images/tools/Redis.png", name: "Redis", url: "#" },
  // { src: "/images/tools/pobeda80_logo_main.png", name: "Победа 80", url: "#" }
];
---

<div class="tools-section">
<div class="tools-section-title">Используем актуальный и легко поддерживаемый стек технологий</div>
<div class="tools-section-text">Определим решение, которое лучше всего подходит под ваши задачи, сроки и бюджет. Легко разберёмся в чём-то новом, если это требуется в проекте.</div>

  <div class="tools-container">
    <div class="tools-scroll">
      <div class="tools-list-1">
        {tools.map((tool, index) => (
          <a href={tool.url} class="tool-item" key={index}>
            <img src={tool.src} alt={tool.name} class="tool-logo" />
            <span class="tool-name" >{tool.name}</span>
          </a>
        ))}
        {/* Дублируем список для бесшовной анимации */}
        {tools.map((tool, index) => (
          <a href={tool.url} class="tool-item" key={`duplicate-${index}`}>
            <img src={tool.src} alt={tool.name} class="tool-logo" />
            <span class="tool-name" >{tool.name}</span>
          </a>
        ))}
      </div>
      <div class="tools-list-2">
        {tools.map((tool, index) => (
          <a href={tool.url} class="tool-item" key={index}>
            <img src={tool.src} alt={tool.name} class="tool-logo" />
            <span class="tool-name" >{tool.name}</span>
          </a>
        ))}
        {/* Дублируем список для бесшовной анимации */}
        {tools.map((tool, index) => (
          <a href={tool.url} class="tool-item" key={`duplicate-${index}`}>
            <img src={tool.src} alt={tool.name} class="tool-logo" />
            <span class="tool-name" >{tool.name}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style is:global lang="scss">
.tools-section {
  margin-top: var(--space-20);
}


.tools-section-title {
  max-width: 960px;
  font-size: var(--text-4xl);
  font-weight: bold;
  text-align: center;
  margin: 0 auto 2rem auto;

  @media (min-width: 768px) {
    font-size: var(--text-5xl);
  }
}

.tools-section-text {
  max-width: 960px;
  font-size: var(--text-lg);
  text-align: center;
  margin: 0 auto;
}

.tools-container {
  overflow: hidden;
  position: relative;
  margin: 0 auto;
  padding: 64px 12px;
  // max-width: var(--container-max);
}

.tools-scroll {
  overflow: hidden;
  position: relative;
  
  &::before,
  &::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 100px;
    z-index: 2;
    pointer-events: none;
  }
  
  &::before {
    left: 0;
    background: linear-gradient(to right, rgba(var(--color-dark-rgb),1) 0%, rgba(var(--color-dark-rgb),0) 100%);
  }
  
  &::after {
    right: 0;
    background: linear-gradient(to left, rgba(var(--color-dark-rgb),1) 0%, rgba(var(--color-dark-rgb),0) 100%);
  }
}

.tools-list-1 {
  display: flex;
  align-items: center;
  padding: 16px 0;
  min-width: min-content;
  margin: 0 2rem;
  @media (min-width: 768px) {
    margin: 0 3rem;
  }
  // height: 75px;
  /* Анимация бегущей строки */
  animation: scroll 50s linear infinite;
}

.tools-list-2 {
  display: flex;
  align-items: center;
  padding: 16px 0;
  min-width: min-content;
  // height: 75px;
  /* Анимация бегущей строки */
  animation: scrolll 50s linear infinite;
}

@keyframes scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(calc(-100% / 2));
  }
}
@keyframes scrolll {
  0% {
    transform: translateX(calc(-100% / 2));
  }
  100% {
    transform: translateX(0);
  }
}

.tool-item {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  height: 100%;
  width: 100px;
  text-decoration: none;
  transition: opacity 0.3s ease;
  @media (min-width: 768px) {
    width: 260px;
  }
}

.tool-name {
  font-size: 14px;
  color: var(--color-white-70);
  margin-top: 8px;
}

.tool-item:hover {
  opacity: 0.8;
}

.tool-logo {
  max-height: 64px;
  max-width: 64px;
  height: 64px;
  width: 64px;
  object-fit: contain;
  transition: all 0.3s ease;
}

.tool-item:hover .tool-logo {
  filter: grayscale(0%);
  opacity: 1;
}

/* Пауза анимации при наведении */
.tools-scroll:hover .tools-list {
  animation-play-state: paused;
}

/* Адаптивность */
