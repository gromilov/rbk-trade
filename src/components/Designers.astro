---
import Button from './UI/Button.astro';
---

<section class="designers" id="designers">
  <div class="designers__container">
    <div class="designers__header">
      <h2 class="designers__title">Дизайнерам интерьеров в Казани и по Татарстану</h2>
      <p class="designers__subtitle">С нами выгодно — эксклюзивные скидки для ваших клиентов и профессиональная поддержка на всех этапах проектирования.</p>
    </div>

    <div class="designers__grid">
      <div class="designers__item">
        <div class="designers__icon">
          <img src="/images/icons/design/Group 1171277575.svg" alt="Лояльность" />
        </div>
        <p class="designers__text">Индивидуальная система лояльности</p>
      </div>

      <div class="designers__item">
        <div class="designers__icon">
          <img src="/images/icons/design/Group 1171277576.svg" alt="Поддержка" />
        </div>
        <p class="designers__text">Полная техническая поддержка проектов</p>
      </div>

      <div class="designers__item">
        <div class="designers__icon">
          <img src="/images/icons/design/Group 1171277576-1.svg" alt="Образцы" />
        </div>
        <p class="designers__text">Предоставление каталогов и образцов</p>
      </div>

      <div class="designers__item">
        <div class="designers__icon">
          <img src="/images/icons/design/Group-1171277576-2.svg" alt="Партнерство" />
        </div>
        <p class="designers__text">Совместное продвижение проектов</p>
      </div>
    </div>

    <div class="designers__footer">
        <Button className="open-form" variant="dark">ПОЛУЧИТЬ СПЕЦПРЕДЛОЖЕНИЕ</Button>
    </div>
  </div>
</section>

<style lang="scss">
.designers {
  padding: var(--space-20) 0;
  background-color: white;

  &__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-4);
    text-align: center;
  }

  &__header {
    max-width: 800px;
    margin: 0 auto var(--space-16);
  }

  &__title {
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    color: #292524;
    margin-bottom: var(--space-6);

    @media (min-width: 768px) {
      font-size: var(--text-5xl);
    }
  }

  &__subtitle {
    font-size: var(--text-lg);
    color: #292524;
    opacity: 0.7;
    line-height: 1.5;
  }

  &__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-16);

    @media (min-width: 640px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media (min-width: 1024px) {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  &__item {
    background-color: #F6F6F6;
    padding: var(--space-10);
    border-radius: var(--radius-2xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    transition: transform var(--transition-base);

    &:hover {
      transform: translateY(-8px);
    }
  }

  &__icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;

    img {
      width: 100%;
      height: 100%;
    }
  }

  &__text {
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--color-dark);
    line-height: 1.4;
  }

  &__footer {
      display: flex;
      justify-content: center;
  }
}
</style>
