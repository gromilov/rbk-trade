---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class={`content-typography ${className}`}>
  <slot />
</div>

<style lang="scss" is:global>
.content-typography {
  // Сброс стилей для чистого HTML
  h2 {
    font-size: 1.5rem;
    font-weight: var(--font-medium);
    margin-bottom: 1rem;
    margin-top: 2.5rem;
    color: inherit;
    
    &:first-child {
      margin-top: 0;
    }
  }

  h3 {
    font-size: 1.25rem;
    font-weight: var(--font-medium);
    margin-bottom: 0.75rem;
    margin-top: 1.5rem;
  }

  p {
    font-size: 1.125rem;
    line-height: var(--leading-relaxed);
    opacity: 0.8;
    margin-bottom: 1rem;
    
    &:last-child {
      margin-bottom: 0;
    }
  }

  // Списки
  ul, ol {
    padding-left: 0;
    margin-bottom: 1.5rem;
    list-style: none;
  }

  li {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    position: relative;
    font-size: 1.125rem;
    line-height: var(--leading-relaxed);
    opacity: 0.8;
  }

  // Маркеры для ul
  ul li::before {
    content: "•";
    color: var(--color-accent);
    font-size: 1.5rem;
    position: absolute;
    left: 0;
    top: -0.25rem;
    line-height: 1.5;
  }

  // Нумерация для ol
  ol {
    counter-reset: item;
    
    li {
      padding-left: 2rem;
      
      &::before {
        content: counter(item) ".";
        counter-increment: item;
        color: var(--color-accent);
        font-weight: var(--font-bold);
        position: absolute;
        left: 0;
        top: 0;
        font-size: 1.125rem;
      }
    }
  }

  // Жирный текст
  strong, b {
    font-weight: var(--font-bold);
    opacity: 1;
  }

  // Курсив
  em, i {
    font-style: italic;
  }

  // Ссылки
  a {
    color: var(--color-accent);
    text-decoration: underline;
    transition: opacity 0.2s;
    
    &:hover {
      opacity: 0.8;
    }
  }

  // Разделитель
  hr {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin: 2rem 0;
  }

  // Цитаты
  blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    opacity: 0.9;
  }

  // Мелкий текст
  small {
    font-size: 0.875rem;
    opacity: 0.7;
  }
}
</style>