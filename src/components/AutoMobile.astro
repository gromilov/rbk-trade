---
// components/AutomationSection.astro
const items = [
    { 
        icon: 'realty.svg', 
        name: 'Недвижимость' 
    },
    { 
        icon: 'marketing.svg', 
        name: 'Маркетинг' 
    },
    { 
        icon: 'logistics.svg', 
        name: 'Логистика и грузоперевозки' 
    },
    { 
        icon: 'production.svg', 
        name: 'Производство' 
    },
    { 
        icon: 'oil.svg', 
        name: 'Нефтегазодобыча' 
    },
    { 
        icon: 'horeca.svg', 
        name: 'Общественное питание и HoReCa' 
    },
    { 
        icon: 'finance.svg',
        name: 'Финансы' 
    }
]
---

<section class="automation-mobile-section">
  <div class="container">
    <div class="automation-mobile-title">
      Автоматизируйте<br>
      <span>любую</span> деятельность
    </div>
    <div class="automation-mobile-list">
       {items.map((item) => (
          <div class="automation-mobile-item">
            <img src={`/images/automation/${item.icon}`} /> {item.name}
          </div>
        ))}
        {items.map((item) => (
          <div class="automation-mobile-item">
            <img src={`/images/automation/${item.icon}`} /> {item.name}
          </div>
        ))}
    </div>
  </div>
  
</section>



<style lang="scss" is:global>
.automation-mobile {
  &-section {
    .container {
      width: 100%;
      max-width: var(--container-max);
      display: block;
      margin: 2rem auto;
      padding:  1rem;
      overflow: hidden;
      position: relative;

      @media (min-width: 768px) {
        display: none;
        margin: -64px auto;
        padding:  0;
      }
    }
  }

  &-list {
    display: flex;
    align-items: center;
    padding: 16px 0;
    min-width: min-content;
    margin: 0 2rem;
    gap: 1rem;
    @media (min-width: 768px) {
      margin: 0 3rem;
    }
    // height: 75px;
    /* Анимация бегущей строки */
    animation: scroll 30s linear infinite;
  }

  &-item {
    flex-shrink: 0;
    display: flex;
    gap: 16px;
    padding: 0 16px 0 0;
    background: var(--color-light);
    border-radius: 56px;
    align-items: center;
  }

  &-title {
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-6);
    line-height: var(--leading-tight);
    text-align: center;
    span {
      color: var(--color-accent)
    }
    @media (min-width: 768px) {
      font-size: var(--text-5xl);
    }
  }

}
</style>