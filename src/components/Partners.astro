---
const { title = "Наши партнеры", text = "", showButton = false } = Astro.props;
---

<section class="partners">
  <div class="partners__container">
    <div class="partners__header">
      <h2 class="partners__title" set:html={title} />
      {text && <p class="partners__subtitle" set:html={text} />}
    </div>

    <div class="partners__grid">
      <!-- Ряд 1 (5 лого) -->
      <div class="partners__row partners__row--top">
        <div class="partners__logo">
          <img src="/images/partners/Frame 1321315517.png" alt="Varmann" />
        </div>
        <div class="partners__logo">
          <img src="/images/partners/Frame 1321315518.png" alt="KZTO" />
        </div>
        <div class="partners__logo">
          <img src="/images/partners/Frame 1321315519.png" alt="SOLIRA" />
        </div>
        <div class="partners__logo">
          <img src="/images/partners/Frame 1321315520.png" alt="EXEMET" />
        </div>
        <div class="partners__logo">
          <img src="/images/partners/Frame 1321315521.png" alt="Radion" />
        </div>
      </div>

      <!-- Ряд 2 (4 лого) -->
      <div class="partners__row partners__row--bottom">
        <div class="partners__logo">
          <img src="/images/partners/Frame 1321315517-1.png" alt="Carisa" />
        </div>
        <div class="partners__logo">
          <img src="/images/partners/Frame 1321315518-1.png" alt="RIFAR" />
        </div>
        <div class="partners__logo">
          <img src="/images/partners/Frame 1321315519-1.png" alt="IRSAP" />
        </div>
        <div class="partners__logo">
          <img src="/images/partners/Frame 1321315520-1.png" alt="VASCO" />
        </div>
      </div>
    </div>

    {
      showButton && (
        <div class="partners__footer">
          <a href="#" class="partners__more">
            СМОТРЕТЬ ВСЕ БРЕНДЫ
          </a>
        </div>
      )
    }
  </div>
</section>

<style lang="scss">
  .partners {
    padding: var(--space-20) 0;
    background-color: var(--color-white);

    &__container {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--space-4);
    }

    &__header {
      text-align: center;
      max-width: 800px;
      margin: 0 auto var(--space-16);
    }

    &__title {
      font-size: var(--text-4xl);
      font-weight: var(--font-bold);
      color: var(--color-dark);
      margin-bottom: var(--space-4);

      @media (min-width: 768px) {
        font-size: var(--text-6xl);
      }
    }

    &__subtitle {
      font-size: var(--text-lg);
      color: var(--color-dark);
      opacity: 0.6;
      line-height: 1.4;
    }

    &__grid {
      display: flex;
      flex-direction: column;
      gap: clamp(var(--space-8), 5vw, var(--space-16));
      margin-bottom: var(--space-16);
    }

    &__footer {
      text-align: center;
    }

    &__more {
      font-size: var(--text-sm);
      font-weight: var(--font-bold);
      color: var(--color-dark);
      text-decoration: none;
      border-bottom: 2px solid var(--color-primary);
      padding-bottom: 4px;
      letter-spacing: 0.05em;
      transition: opacity var(--transition-fast);

      &:hover {
        opacity: 0.7;
      }
    }

    &__row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: clamp(var(--space-4), 3vw, var(--space-12));

      &--top {
        @media (min-width: 1024px) {
          justify-content: space-between;
        }
      }
    }

    &__logo {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 160px; // Немного меньше для мобильных по умолчанию
      height: 100px;

      @media (min-width: 768px) {
        width: 192px;
        height: 120px;
      }

      img {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
      }
    }
  }
</style>
