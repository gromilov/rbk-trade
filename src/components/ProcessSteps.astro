---
// Данные для этапов
const { steps: propSteps } = Astro.props;

const steps = propSteps || [
  {
    number: "54",
    text: "Сокращение затрат"
  },
  {
    number: "95",
    text: "Сокращение ручного ввода"
  },
  {
    number: "50",
    text: "Увеличение продуктивности"
  }
];
---

<section class="statistics-section">
  <div class="statistics-section__container">
    <div class="statistics-section__grid">
      {steps.map((step, index) => (
        <div class={`statistics-item ${index > 0 ? 'statistics-item--bordered' : ''}`}>
          <div class="statistics-item__number-wrapper">
            до <span class="statistics-item__number">{step.number}%</span>
          </div>
          <div class="statistics-item__content">
            <p class="statistics-item__text">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss" is:global>

.statistics-section {
  padding: 0 var(--space-4);
  
  
  @media (min-width: 768px) {
    padding: 0;
  }
  
  &__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    
    @media (min-width: 768px) {
      padding-left: var(--space-4);
      padding-right: var(--space-4);
    }
  }
  
  &__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin: 0 auto;
    
    @media (min-width: 768px) {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }
  }
}

.statistics-item {
  text-align: center;
  margin-top: var(--space-3);
  
  @media (min-width: 768px) {
    position: relative;
    
    &--bordered {
      &::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 1px;
        background-color: rgba(255, 255, 255, 0.1);
      }
    }
  }
  
  &__number-wrapper {
    font-size: var(--text-lg);
    color: var(--color-white);
    margin-bottom: var(--space-4);
  }
  
  &__number {
    font-size: var(--text-6xl);
    font-weight: var(--font-bold);
    color: var(--color-white);
    line-height: 1;
  }
  
  &__content {
    padding: 0 var(--space-4);
  }
  
  &__text {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-4);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }
}
</style>