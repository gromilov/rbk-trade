<section class="advantages">
  <div class="advantages__container">
    <h2 class="advantages__title">Преимущества работы с нами</h2>
    
    <div class="advantages__grid">
      <!-- Преимущество 1 -->
      <div class="advantages__item">
        <div class="advantages__icon-wrapper">
          <img src="/images/icons/advantages/Group 1171277575.svg" alt="Монтаж" class="advantages__icon" />
        </div>
        <p class="advantages__text">Монтаж от 1 дня в Казани</p>
      </div>

      <!-- Преимущество 2 -->
      <div class="advantages__item">
        <div class="advantages__icon-wrapper">
          <img src="/images/icons/advantages/Group 1171277575-1.svg" alt="Консультация" class="advantages__icon" />
        </div>
        <p class="advantages__text">Консультация по подбору</p>
      </div>

      <!-- Преимущество 3 -->
      <div class="advantages__item">
        <div class="advantages__icon-wrapper">
          <img src="/images/icons/advantages/Group 1171277575-2.svg" alt="Оплата" class="advantages__icon" />
        </div>
        <p class="advantages__text">Гибкие условия оплаты</p>
      </div>

      <!-- Преимущество 4 -->
      <div class="advantages__item">
        <div class="advantages__icon-wrapper">
          <img src="/images/icons/advantages/Group 1171277575-3.svg" alt="Наличие" class="advantages__icon" />
        </div>
        <p class="advantages__text">Любой выбор радиаторов в наличии</p>
      </div>

      <!-- Преимущество 5 -->
      <div class="advantages__item">
        <div class="advantages__icon-wrapper">
          <img src="/images/icons/advantages/Group 1171277575-4.svg" alt="Бригады" class="advantages__icon" />
        </div>
        <p class="advantages__text">Свои монтажные бригады, стаж более 10 лет монтажа отопительных систем любой сложности</p>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
.advantages {
  padding: var(--space-20) 0;
  background-color: var(--color-white);

  &__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }

  &__title {
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin-bottom: var(--space-16);
    text-align: center;

    @media (min-width: 768px) {
      font-size: var(--text-6xl);
    }
  }

  &__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-8);
    max-width: 1000px;
    margin: 0 auto;

    @media (min-width: 1024px) {
      gap: var(--space-12) var(--space-20);
    }
  }

  &__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-6);
    transition: transform var(--transition-fast);
    width: 100%;

    @media (min-width: 640px) {
      width: calc(50% - var(--space-8));
    }

    @media (min-width: 1024px) {
      width: calc(33.33% - var(--space-20));
      
      // Специфическое выравнивание для 4 и 5 элементов
      &:nth-child(4) {
        margin-left: 0; // Можно добавить отступы для более точного позиционирования
      }
    }

    &:hover {
      transform: translateY(-5px);
    }
  }

  &__icon-wrapper {
    background-color: var(--color-light);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-6);

    img {
      object-fit: contain;
    }
  }

  &__text {
    font-size: var(--text-base);
    line-height: var(--leading-tight);
    color: var(--color-dark);
    font-weight: var(--font-medium);
    max-width: 200px;
  }
}
</style>
