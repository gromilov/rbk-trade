---

<section class="certificates">
  <div class="certificates__container">
    <h2 class="certificates__title">Сертификаты</h2>
    
    <div class="certificates__grid">
      <div class="certificates__item">
        <img src="/images/certificates/image 11.png" alt="Сертификат EXEMET" class="certificates__img" />
      </div>
      <div class="certificates__item">
        <img src="/images/certificates/image 8.png" alt="Сертификат SOLE" class="certificates__img" />
      </div>
      <div class="certificates__item">
        <img src="/images/certificates/image 9.png" alt="Сертификат LULLY" class="certificates__img" />
      </div>
      <div class="certificates__item">
        <img src="/images/certificates/image 10.png" alt="Сертификат DEVI" class="certificates__img" />
      </div>
    </div>
  </div>
</section>

<style lang="scss">
.certificates {
  padding: var(--space-20) 0;
  background-color: var(--color-white);

  &__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }

  &__title {
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin-bottom: var(--space-12);
    text-align: center;

    @media (min-width: 768px) {
      font-size: var(--text-6xl);
    }
  }

  &__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 26px;
  }

  &__item {
    flex: 0 0 auto;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(17, 17, 17, 0.16);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    cursor: pointer;
    background-color: white;

    &:hover {
      transform: translateY(-8px);
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1);
    }
  }

  &__img {
    height: 220px; // Адаптивно для маленьких
    width: auto;
    display: block;
    object-fit: contain;

    @media (min-width: 1024px) {
      height: 319px;
    }
  }
}
</style>
