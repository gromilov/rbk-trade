---
import db from "../lib/db";

const {
  variant = "reasons", // "reasons" or "manufacturers"
  title = "Почему клиенты возвращаются к нам?",
  subtitle = "Дизайнерские радиаторы, которым доверяют профессионалы",
} = Astro.props;

// Получаем бренды из БД
const manufacturers = db
  .prepare("SELECT * FROM manufacturers ORDER BY sort_order ASC")
  .all();

// Получаем фото проектов, сгруппированные по брендам
const projects = db
  .prepare(
    `
  SELECT main_image, manufacturer_id 
  FROM cases 
  WHERE main_image IS NOT NULL AND main_image != ''
`,
  )
  .all();

const brandData = {};
manufacturers.forEach((m) => {
  brandData[m.id] = projects
    .filter((p) => p.manufacturer_id === m.id)
    .map((p) => p.main_image);
});

// Начальный набор слайдов (первый бренд или заглушки)
const initialBrandId = manufacturers[0]?.id;
const initialSlides =
  brandData[initialBrandId]?.length > 0
    ? brandData[initialBrandId]
    : [
        "/images/carousel/Rectangle 153.png",
        "/images/carousel/Rectangle 154.png",
        "/images/carousel/Rectangle 155.png",
      ];
---

<section
  class={`reasons ${variant === "manufacturers" ? "reasons--manufacturers" : ""}`}
  id="reasons"
>
  <div class="reasons__container">
    {
      variant === "reasons" ? (
        <div class="reasons__header">
          <div class="reasons__title-box">
            <h2 class="reasons__title">{title}</h2>
          </div>
          <div class="reasons__list-box">
            <ul class="reasons__list">
              <li class="reasons__item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M5 13L9 17L19 7"
                    stroke="var(--color-primary)"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <span>Консультация специалистов</span>
              </li>
              <li class="reasons__item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M5 13L9 17L19 7"
                    stroke="var(--color-primary)"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <span>Различный ценовой диапазон товаров</span>
              </li>
              <li class="reasons__item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M5 13L9 17L19 7"
                    stroke="var(--color-primary)"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <span>Двухэтажный шоурум в центре города</span>
              </li>
              <li class="reasons__item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M5 13L9 17L19 7"
                    stroke="var(--color-primary)"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <span>
                  Свои сантехнические бригады, стаж более 10 лет монтажа
                  отопительных систем любой сложности
                </span>
              </li>
            </ul>
          </div>
        </div>
      ) : (
        <div class="manufacturers-header">
          <h2 class="reasons__title">{title}</h2>
          <p class="reasons__subtitle">{subtitle}</p>

          <div class="reasons__tabs">
            {manufacturers.map((brand, index) => (
              <button
                class={`brand-tab ${index === 0 ? "active" : ""}`}
                data-brand={brand.id}
              >
                {brand.name}
              </button>
            ))}
          </div>
        </div>
      )
    }

    <!-- Слайдер -->
    <div class="reasons__slider-container">
      <div class="reasons__slider" id="reasonsSlider">
        {
          initialSlides.map((img) => (
            <div class="reasons__slide">
              <div
                class={variant === "manufacturers" ? "slide-card-manuf" : ""}
              >
                <img src={img} alt="Проект" class="reasons__img" />
              </div>
            </div>
          ))
        }
      </div>

      <div class="reasons__controls">
        <button class="reasons__nav-btn reasons__nav-btn--prev">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        <div class="reasons__progress-container">
          <div class="reasons__progress-bar"></div>
        </div>
        <button class="reasons__nav-btn reasons__nav-btn--next">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </div>

    {
      variant === "manufacturers" && (
        <div class="reasons__footer">
          <button class="reasons__cta" data-modal="formModal">
            Заказать подбор радиаторов под проект
          </button>
        </div>
      )
    }
  </div>

  <script is:inline define:vars={{ brandData }}>
    window.BRAND_DATA = brandData;
  </script>
</section>

<style lang="scss">
  .reasons {
    padding: 80px 0;
    background-color: var(--color-white);
    overflow: hidden;

    &__container {
      margin: 0 auto;
      position: relative;
      max-width: var(--container-max);
      padding: 0 var(--space-4);
    }

    &__slider-container {
      width: 100%;
      position: relative;

      &::before {
        content: "";
        position: absolute;
        top: 0;
        left: -1px;
        width: 100px;
        height: 100%;
        background: linear-gradient(to right, var(--color-white), transparent);
        z-index: 2;
        pointer-events: none;
        @media (max-width: 1023px) {
          width: 40px;
        }
      }

      &::after {
        content: "";
        position: absolute;
        top: 0;
        right: -1px;
        width: 100px;
        height: 100%;
        background: linear-gradient(to left, var(--color-white), transparent);
        z-index: 2;
        pointer-events: none;
        @media (max-width: 1023px) {
          width: 40px;
        }
      }
    }

    &__slider {
      display: flex;
      gap: 24px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      scroll-behavior: smooth;
      padding-bottom: 10px;

      &::-webkit-scrollbar {
        display: none;
      }
      
      :global(.reasons__slide) {
        flex: 0 0 384px;
        scroll-snap-align: start;
        @media (max-width: 767px) {
          flex: 0 0 100%;
        }
      }

      :global(.slide-card-manuf) {
        width: 100%;
        aspect-ratio: 1/1;
        border-radius: 24px;
        overflow: hidden;
        
        :global(.reasons__img) {
          width: 100%;
          height: 100%;
          object-fit: cover;
        }
      }
      
      :global(.reasons__img) {
        width: 100%;
        height: 384px;
        object-fit: cover;
        border-radius: var(--radius-2xl);
      }
    }

    &__header {
      display: flex;
      flex-direction: column;
      gap: var(--space-8);
      margin-bottom: var(--space-16);

      @media (min-width: 1024px) {
        flex-direction: row;
        justify-content: space-between;
        align-items: flex-start;
      }
    }

    &__title {
      font-size: clamp(32px, 5vw, 64px);
      font-weight: 700;
      color: var(--color-dark);
      line-height: 1.1;
      max-width: 950px;
    }

    &__list {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    &__item {
      display: flex;
      gap: var(--space-4);
      align-items: flex-start;
      svg {
        flex-shrink: 0;
        margin-top: 4px;
      }
      span {
        font-size: var(--text-lg);
        line-height: 1.4;
        color: var(--color-dark);
      }
    }

    &--manufacturers {
      .manufacturers-header {
        text-align: center;
        margin-bottom: 48px;
        .reasons__title {
          margin: 0 auto 24px;
        }
      }

      .reasons__subtitle {
        font-size: 20px;
        color: #111111;
        opacity: 0.8;
        margin-bottom: 40px;
      }

      .reasons__tabs {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 12px;
      }

      .brand-tab {
        padding: 12px 32px;
        border-radius: 100px;
        border: 1px solid rgba(17, 17, 17, 0.12);
        background: transparent;
        font-size: 16px;
        color: #111111;
        cursor: pointer;
        transition: all 0.3s ease;
        &.active {
          background: #111111;
          color: #fff;
          border-color: #111111;
        }
      }

      .reasons__cta {
        background: #111111;
        color: #ffffff;
        padding: 24px 48px;
        border-radius: 100px;
        font-size: 18px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: transform 0.3s ease;
        margin-top: 60px;
        &:hover {
          transform: scale(1.02);
        }
      }
    }

    &__controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-8);
      margin-top: var(--space-10);
    }

    &__nav-btn {
      width: 48px;
      height: 48px;
      border-radius: var(--radius-full);
      border: 1px solid #e5e7eb;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      cursor: pointer;
      transition: all var(--transition-fast);
      color: #9ca3af;
      &:hover {
        border-color: #111111;
        color: #111111;
      }
    }

    &__progress-container {
      width: 100%;
      max-width: 400px;
      height: 2px;
      background: #e5e7eb;
      position: relative;
    }

    &__progress-bar {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 0%;
      background: var(--color-primary);
      transition: width 0.2s ease;
    }

    &__footer {
      display: flex;
      justify-content: center;
    }
  }
</style>

<script>
  function initReasonsSections() {
    const reasonsSections = document.querySelectorAll(".reasons");
    
    reasonsSections.forEach((section: any) => {
      const slider = section.querySelector(".reasons__slider") as HTMLElement;
      const progressBar = section.querySelector(".reasons__progress-bar") as HTMLElement;
      const prevBtn = section.querySelector(".reasons__nav-btn--prev");
      const nextBtn = section.querySelector(".reasons__nav-btn--next");
      
      if (!slider) return;

      // Update progress bar
      const updateProgress = () => {
        if (!progressBar) return;
        const scrollLeft = slider.scrollLeft;
        const scrollWidth = slider.scrollWidth - slider.clientWidth;
        const progress = scrollWidth > 0 ? (scrollLeft / scrollWidth) * 100 : 0;
        progressBar.style.width = `${progress}%`;
      };

      slider.addEventListener("scroll", updateProgress);
      window.addEventListener("resize", updateProgress);
      updateProgress();

      // Navigation
      if (prevBtn) {
        prevBtn.addEventListener("click", () => {
          const scrollAmount = slider.clientWidth > 800 ? 408 : slider.clientWidth;
          slider.scrollBy({ left: -scrollAmount, behavior: "smooth" });
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener("click", () => {
          const scrollAmount = slider.clientWidth > 800 ? 408 : slider.clientWidth;
          slider.scrollBy({ left: scrollAmount, behavior: "smooth" });
        });
      }

      // Tabs
      const tabs = section.querySelectorAll(".brand-tab");
      tabs.forEach((tab: HTMLElement) => {
        tab.addEventListener("click", () => {
          const brandId = tab.getAttribute("data-brand");
          if (!brandId) return;

          tabs.forEach((t) => t.classList.remove("active"));
          tab.classList.add("active");

          updateSlides(slider, brandId);
        });
      });

      // CTA
      const cta = section.querySelector(".reasons__cta");
      if (cta) {
        cta.addEventListener("click", () => {
          const modalId = cta.getAttribute("data-modal");
          const modal = modalId ? document.getElementById(modalId) : null;
          if (modal) modal.classList.add("active");
        });
      }
    });
  }

  function updateSlides(slider: HTMLElement, brandId: string) {
    const data = (window as any).BRAND_DATA || {};
    const images = data[brandId] || [];

    // Fallback if no images
    const finalImages =
      images.length > 0
        ? images
        : [
            "/images/carousel/Rectangle 153.png",
            "/images/carousel/Rectangle 154.png",
            "/images/carousel/Rectangle 155.png",
          ];

    const slidesHtml = finalImages.map(
      (img: string) => `
      <div class="reasons__slide">
        <div class="slide-card-manuf">
          <img src="${img}" alt="Проект" class="reasons__img" loading="lazy" />
        </div>
      </div>
    `,
    ).join('');
    
    slider.innerHTML = slidesHtml;
    slider.scrollLeft = 0;
  }

  // Run on initial load
  initReasonsSections();
  
  // Run on View Transitions navigation
  document.addEventListener("astro:after-swap", initReasonsSections);
</script>
