<style lang="scss" is:global>

#automation-section {
  .container {
    width: 100%;
    max-width: var(--container-max);
    display: none;
    @media (min-width: 768px) {
      display: block;
      margin: -64px auto;
      padding:  0;
    }
  }
  
  .automation-wrapper {
    text-align: center;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }



.icon-bg {
  transition: fill 0.3s ease-out;
}

.icon-path {
  transition: stroke 0.3s ease-out;
}

/* Классы для активации через JS */
.icon-active .icon-bg {
  fill: #ffb251 !important;
}

.icon-active .icon-path {
  stroke: #1a1a1a !important;
}

/* Эффект пульсации для активных иконок */
@keyframes pulse {
  0% {
    filter: drop-shadow(0 0 0 rgba(255, 178, 81, 0));
  }
  50% {
    filter: drop-shadow(0 0 8px rgba(255, 178, 81, 0.4));
  }
  100% {
    filter: drop-shadow(0 0 0 rgba(255, 178, 81, 0));
  }
}

.icon-active {
  animation: pulse 1s ease-out;
}

/* Адаптивность */
@media (max-width: 768px) {
  #automation-section svg {
    width: 100%;
    height: auto;
    max-width: 600px;
  }
  
  .icon-bg,
  .icon-path {
    transition-duration: 0.2s !important;
  }
}

/* Поддержка prefers-reduced-motion */
@media (prefers-reduced-motion: reduce) {
  #orange-line,
  .icon-bg,
  .icon-path {
    transition-duration: 0.01ms !important;
    animation-duration: 0.01ms !important;
  }
}
}
</style>