---
import Button from "./UI/Button.astro";
---

<section class="projects" id="projects">
  <div class="projects__container">
    <h2 class="projects__title">Почему дизайнеры доверяют нам свои проекты?</h2>

    <div class="projects__grid">
      <!-- Ряд 1: Кол 1 -->
      <div class="projects__card">
        <div class="projects__card-icon">
          <img src="/images/icons/projects/Group 1171277575.svg" alt="Иконка" />
        </div>
        <div class="projects__card-content">
          <h3 class="projects__card-title">
            Прозрачность и без скрытых согласований
          </h3>
          <p class="projects__card-text">
            Фиксируем стоимость до старта, согласовываем с вами, не общаемся с
            клиентом за вашей спиной.
          </p>
        </div>
      </div>

      <!-- Ряд 1: Кол 2 -->
      <div class="projects__card">
        <div class="projects__card-icon">
          <img src="/images/icons/projects/Group 1171277576.svg" alt="Иконка" />
        </div>
        <div class="projects__card-content">
          <h3 class="projects__card-title">
            Работаем с любыми бюджетами и стилями
          </h3>
          <p class="projects__card-text">
            Минимализм, классика, лофт, сканди, хай-тек — подберем под каждый
            стиль.
          </p>
        </div>
      </div>

      <!-- Ряд 1-2: Кол 3 (Featured) -->
      <div class="projects__featured">
        <div class="projects__featured-icon">
          <img
            src="/images/icons/projects/Group 1171277575-1.svg"
            alt="Иконка"
          />
        </div>
        <h3 class="projects__featured-title">
          Индивидуальные условия для дизайнеров
        </h3>
        <ul class="projects__featured-list">
          <li>Партнёрский прайс</li>
          <li>Бонусная программа</li>
          <li>КП за 1 день</li>
          <li>Закрытый чат</li>
        </ul>
        <div class="projects__featured-footer">
          <Button className="open-form" variant="dark">Обсудить проект</Button>
        </div>
      </div>

      <!-- Ряд 2: Кол 1 -->
      <div class="projects__card">
        <div class="projects__card-icon">
          <img
            src="/images/icons/projects/Group 1171277575 — копия.svg"
            alt="Иконка"
          />
        </div>
        <div class="projects__card-content">
          <h3 class="projects__card-title">Помогаем продать решение клиенту</h3>
          <p class="projects__card-text">
            Референсы, сравнение «обычный vs дизайн», визуализации, живые
            образцы в шоурумах.
          </p>
        </div>
      </div>

      <!-- Ряд 2: Кол 2 -->
      <div class="projects__card">
        <div class="projects__card-icon">
          <img
            src="/images/icons/projects/Group 1171277576-1.svg"
            alt="Иконка"
          />
        </div>
        <div class="projects__card-content">
          <h3 class="projects__card-title">
            Берем на себя замеры и проектирование
          </h3>
          <p class="projects__card-text">
            Профессиональный обмер помещений, подбор оборудования и авторский
            надзор на объекте.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .projects {
    padding: var(--space-20) 0;
    background-color: var(--color-white);

    &__container {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--space-4);
    }

    &__title {
      font-size: var(--text-4xl);
      font-weight: var(--font-bold);
      color: var(--color-dark);
      margin-bottom: var(--space-12);
      text-align: center;
      max-width: 900px;
      margin-left: auto;
      margin-right: auto;

      @media (min-width: 768px) {
        font-size: var(--text-6xl);
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
      justify-content: center;

      @media (min-width: 1024px) {
        grid-template-columns: 384px 384px 384px;
        grid-auto-flow: dense;
      }
    }

    &__card {
      background-color: #f6f6f6;
      padding: 32px;
      border-radius: 16px;
      height: 287px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transition: transform var(--transition-base);

      &:hover {
        transform: translateY(-8px);
      }
    }

    &__card-icon {
      width: 64px;
      height: 64px;

      img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
    }

    &__card-title {
      font-size: 16px;
      font-weight: var(--font-bold);
      color: #292524;
      margin-bottom: 8px;
      line-height: 1.25;
    }

    &__card-text {
      font-size: 14px;
      color: #292524;
      opacity: 0.72;
      line-height: 1.5;
    }

    &__featured {
      background-color: #de6d20;
      padding: 32px;
      border-radius: 16px;
      height: 598px;
      color: white;
      display: flex;
      flex-direction: column;
      grid-row: span 1;

      @media (min-width: 1024px) {
        grid-column: 3;
        grid-row: 1 / 3;
      }

      &-icon {
        width: 64px;
        height: 64px;
        margin-bottom: 24px;

        img {
          width: 100%;
          height: 100%;
          object-fit: contain;
        }
      }

      &-title {
        font-size: 32px;
        font-weight: var(--font-bold);
        margin-bottom: 32px;
        line-height: 1.2;
        letter-spacing: -0.02em;
      }

      &-list {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 24px;
        margin-bottom: 32px;

        li {
          display: flex;
          align-items: center;
          gap: 16px;
          font-size: 16px;
          font-weight: var(--font-medium);

          &::before {
            content: "";
            width: 20px;
            height: 20px;
            background: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M5 13L9 17L19 7' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E")
              no-repeat center;
            flex-shrink: 0;
          }
        }
      }
      &-footer {
        display: flex;

        :global(.btn) {
          width: 100%;
        }
      }
    }
  }
</style>
