---
export const prerender = false;
import ManagerLayout from "../../layouts/ManagerLayout.astro";
import db from "../../lib/db";

const faqs = db.prepare('SELECT * FROM faqs ORDER BY sort_order ASC, id DESC').all();
---

<ManagerLayout title="Управление FAQ">
  <div class="faq-manager">
    <!-- Форма добавления -->
    <div class="card">
      <h3 class="card-title">Добавить новый вопрос</h3>
      <div class="form-add">
        <div class="form-group">
          <label>Вопрос</label>
          <input type="text" id="new-q" placeholder="Напр. Каков срок гарантии?" />
        </div>
        <div class="form-group">
          <label>Ответ</label>
          <textarea id="new-a" placeholder="Текст ответа..." rows="3"></textarea>
        </div>
        <button class="btn-primary" onclick="addFaq(this)">Добавить в список</button>
      </div>
    </div>

    <!-- Список -->
    <div class="faq-list">
      <h3 class="section-title">Список вопросов ({faqs.length})</h3>
      {faqs.map((faq, index) => (
        <div class="faq-item card" data-id={faq.id}>
          <div class="faq-item__reorder">
             <button class="btn-order" onclick={`moveFaq(${faq.id}, 'up')`} disabled={index === 0}>🔼</button>
             <button class="btn-order" onclick={`moveFaq(${faq.id}, 'down')`} disabled={index === faqs.length - 1}>🔽</button>
          </div>
          <div class="faq-item__fields">
            <div class="form-group">
              <label>Вопрос</label>
              <input type="text" class="faq-q" value={faq.question} />
            </div>
            <div class="form-group">
              <label>Ответ</label>
              <textarea class="faq-a" rows="3">{faq.answer}</textarea>
            </div>
          </div>
          <div class="faq-item__actions">
            <button class="btn-save" onclick={`saveFaq(${faq.id}, this)`}>Сохранить изменения</button>
            <button class="btn-del" onclick={`deleteFaq(${faq.id}, this)`}>🗑️</button>
          </div>
        </div>
      ))}
    </div>
  </div>
</ManagerLayout>

<script>
  (window as any).moveFaq = async (id: number, direction: 'up' | 'down') => {
    const res = await fetch('/api/manager/faq', {
      method: 'PATCH',
      body: JSON.stringify({ id, direction }),
      headers: { 'Content-Type': 'application/json' }
    });
    if (res.ok) window.location.reload();
  };
  (window as any).addFaq = async (btn: HTMLButtonElement) => {
    const q = (document.getElementById('new-q') as HTMLInputElement).value;
    const a = (document.getElementById('new-a') as HTMLTextAreaElement).value;
    
    if (!q || !a) return alert('Заполните поле вопроса и ответа');

    btn.disabled = true;
    btn.innerText = 'Добавление...';

    const res = await fetch('/api/manager/faq', {
      method: 'POST',
      body: JSON.stringify({ question: q, answer: a }),
      headers: { 'Content-Type': 'application/json' }
    });

    if (res.ok) window.location.reload();
    else {
      alert('Ошибка при добавлении');
      btn.disabled = false;
      btn.innerText = 'Добавить в список';
    }
  };

  (window as any).saveFaq = async (id: number, btn: HTMLButtonElement) => {
    const item = btn.closest('.faq-item') as HTMLElement;
    const q = (item.querySelector('.faq-q') as HTMLInputElement).value;
    const a = (item.querySelector('.faq-a') as HTMLTextAreaElement).value;

    btn.disabled = true;
    btn.innerText = 'Сохранение...';

    const res = await fetch('/api/manager/faq', {
      method: 'POST',
      body: JSON.stringify({ id, question: q, answer: a }),
      headers: { 'Content-Type': 'application/json' }
    });

    if (res.ok) {
      btn.innerText = '✅ Сохранено';
      setTimeout(() => {
        btn.innerText = 'Сохранить изменения';
        btn.disabled = false;
      }, 2000);
    } else {
      alert('Ошибка при сохранении');
      btn.disabled = false;
      btn.innerText = 'Сохранить изменения';
    }
  };

  (window as any).deleteFaq = async (id: number, btn: HTMLButtonElement) => {
    if (!confirm('Удалить этот вопрос?')) return;
    
    const res = await fetch('/api/manager/faq', {
      method: 'DELETE',
      body: JSON.stringify({ id }),
      headers: { 'Content-Type': 'application/json' }
    });

    if (res.ok) {
      btn.closest('.faq-item')?.remove();
    } else {
      alert('Ошибка при удалении');
    }
  };
</script>

<style lang="scss">
  .faq-manager {
    display: grid;
    gap: 32px;
  }

  .card {
    background: #FFFFFF;
    padding: 32px;
    border-radius: 32px;
    border: 1px solid rgba(0,0,0,0.05);
  }

  .card-title {
    font-size: 18px;
    font-weight: 800;
    margin-bottom: 24px;
    color: var(--color-primary);
  }

  .section-title {
    font-size: 14px;
    font-weight: 800;
    color: #999;
    text-transform: uppercase;
    margin-bottom: 20px;
    letter-spacing: 0.05em;
  }

  .form-add {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .faq-list {
    display: grid;
    gap: 20px;
  }

  .faq-item {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 20px;
    position: relative;

    @media (max-width: 640px) {
      grid-template-columns: 1fr;
    }

    &__reorder {
      display: flex;
      flex-direction: column;
      gap: 8px;
      justify-content: center;
      align-items: center;
      background: #F9FAFB;
      border-radius: 16px;
      padding: 10px;

      @media (max-width: 640px) {
        flex-direction: row;
        justify-content: flex-start;
        background: transparent;
        padding: 0;
      }
    }

    .btn-order {
      background: white;
      border: 1px solid #EEE;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 14px;
      transition: all 0.2s ease;
      &:hover:not(:disabled) { border-color: var(--color-primary); transform: translateY(-2px); }
      &:disabled { opacity: 0.3; cursor: not-allowed; }
    }

    &__fields {
      display: grid;
      gap: 16px;
    }

    &__actions {
      grid-column: 1 / -1; // Full width
      display: flex;
      gap: 12px;
      padding-top: 16px;
      border-top: 1px solid #F0F0F0;
    }

    .btn-save {
      flex: 1;
      background: #F6F6F6;
      border: none;
      padding: 12px;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
      &:hover { background: #EEE; }
      &:disabled { opacity: 0.7; }
    }

    .btn-del {
      background: #FEF2F2;
      border: none;
      padding: 12px;
      border-radius: 12px;
      cursor: pointer;
    }
  }

  // Общие стили для форм (из шаблона) повторяем тут для уверенности
  .form-group {
    label {
      display: block; font-size: 12px; font-weight: 800; color: #999; text-transform: uppercase; margin-bottom: 8px;
    }
    input, textarea {
      width: 100%; background: #F9FAFB; border: 1px solid rgba(0,0,0,0.1); border-radius: 12px; padding: 12px 16px; font-size: 16px; font-family: inherit;
      &:focus { border-color: var(--color-primary); outline: none; background: white; }
    }
  }
</style>
