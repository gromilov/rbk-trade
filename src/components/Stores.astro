---
import db from "../lib/db";
const stores = db.prepare('SELECT * FROM stores').all();
---

<section class="stores" id="stores">
  <div class="stores__container">
    <h2 class="stores__title">Наши магазины</h2>
    
    <div class="stores__grid">
      <!-- Оранжевая карточка (статичная) -->
      <div class="stores__info-card">
        <h3 class="stores__info-title">Шоурумы — для легкого выбора</h3>
        <ul class="stores__info-list">
          <li class="stores__info-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 13L9 17L19 7" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Более 110 тыс. товаров в наличии</span>
          </li>
          <li class="stores__info-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 13L9 17L19 7" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Возможность заказать в индивидуальном цвете</span>
          </li>
          <li class="stores__info-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 13L9 17L19 7" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Удобное расположение в центре</span>
          </li>
        </ul>
      </div>

      <!-- Список магазинов из базы -->
      {stores.map((store) => (
        <div class="stores__card">
          <div class="stores__card-content">
            <h4 class="stores__card-title">{store.title}</h4>
            <p class="stores__card-address">{store.address}</p>
            <div class="stores__card-phones">
              {store.phone?.split(',').map(p => (
                <a href={`tel:${p.replace(/[^\d+]/g, '')}`}>{p.trim()}</a>
              ))}
            </div>
            {store.map_url && (
              <a href={store.map_url} target="_blank" class="stores__btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2L4.5 20.29L5.21 21L12 18L18.79 21L19.5 20.29L12 2Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Как добраться
              </a>
            )}
          </div>
          {store.map_url && (
            <div class="stores__map">
              <iframe 
                src={store.map_url.includes('yandex.ru/maps') ? store.map_url.replace('maps', 'map-widget/v1') : ''} 
                width="100%" 
                height="250" 
                frameborder="0" 
                allowfullscreen="true" 
                style="position:relative;"
              ></iframe>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
.stores {
  padding: var(--space-20) 0;
  background-color: var(--color-white);

  &__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }

  &__title {
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin-bottom: var(--space-16);
    text-align: center;

    @media (min-width: 768px) {
      font-size: var(--text-6xl);
    }
  }

  &__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);

    @media (min-width: 1024px) {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  &__info-card {
    background-color: var(--color-primary);
    padding: var(--space-10);
    border-radius: var(--radius-2xl);
    color: white;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  &__info-title {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-8);
    line-height: var(--leading-tight);
  }

  &__info-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  &__info-item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;

    svg {
      flex-shrink: 0;
      margin-top: 4px;
    }

    span {
      font-size: var(--text-lg);
      line-height: var(--leading-normal);
    }
  }

  &__card {
    background-color: #F9FAFB;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  &__card-content {
    padding: var(--space-8);
    flex: 1;
  }

  &__card-title {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-dark);
    margin-bottom: var(--space-4);
  }

  &__card-address {
    color: var(--color-dark);
    opacity: 0.6;
    margin-bottom: var(--space-4);
    font-size: var(--text-base);
  }

  &__card-phones {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-6);

    a {
      color: var(--color-dark);
      font-weight: var(--font-medium);
      text-decoration: none;
      
      &:hover {
        color: var(--color-primary);
      }
    }
  }

  &__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    padding: var(--space-4);
    background-color: var(--color-dark);
    color: white;
    border-radius: var(--radius-full);
    text-decoration: none;
    font-weight: var(--font-bold);
    transition: background-color var(--transition-base);

    &:hover {
      background-color: var(--color-primary);
    }
  }

  &__map {
    height: 250px;
    background-color: #EEE;
    
    iframe {
      filter: grayscale(0.2);
    }
  }
}
</style>
