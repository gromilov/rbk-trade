---
const { item = {} } = Astro.props;
---

<div class="review-card">
  <div class="review-header">
    <div class="author-box">
      <img
        src={item.image || "/images/Avatar.png"}
        alt={item.name}
        class="author-image"
      />
      <div class="author-info">
        <span class="author-name">{item.name}</span>
        <span class="author-position">{item.position}</span>
      </div>
    </div>

    <div class="rating-stars">
      {
        [...Array(5)].map(() => (
          <svg width="24" height="24" viewBox="0 0 24 24" fill="#FFC107">
            <path d="M12 17.27L18.18 21L16.54 13.97L22 9.24L14.81 8.63L12 2L9.19 8.63L2 9.24L7.46 13.97L5.82 21L12 17.27Z" />
          </svg>
        ))
      }
    </div>
  </div>

  <div class="review-body">
    <p class="review-text">{item.text}</p>
  </div>
</div>

<style lang="scss">
  .review-card {
    background-color: #f6f6f6;
    border-radius: 16px;
    padding: 32px;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 32px;
    transition: transform 0.3s ease;

    @media (max-width: 767px) {
      padding: 24px;
      gap: 24px;
    }
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;

    @media (max-width: 500px) {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .author-box {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .author-image {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;

    @media (max-width: 767px) {
      width: 60px;
      height: 60px;
    }
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .author-name {
    font-size: 24px;
    font-weight: 700;
    color: #111111;
    line-height: 1.2;

    @media (max-width: 767px) {
      font-size: 20px;
    }
  }

  .author-position {
    font-size: 18px;
    color: #111111;
    opacity: 0.64;

    @media (max-width: 767px) {
      font-size: 16px;
    }
  }

  .rating-stars {
    display: flex;
    gap: 4px;
    padding-top: 8px;

    svg {
      width: 20px;
      height: 20px;
    }
  }

  .review-body {
    flex-grow: 1;
  }

  .review-text {
    font-size: 18px;
    line-height: 1.5;
    color: #111111;
    font-weight: 400;

    @media (max-width: 767px) {
      font-size: 16px;
    }
  }
</style>
