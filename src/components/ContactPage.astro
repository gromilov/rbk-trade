<style lang="scss" is:global>
.contact-page {
  
  border-radius: var(--radius-xl);
  padding: 1rem;
  color: var(--color-dark);
  width: 100%;
  margin-left: auto;
  margin-right: auto;
  margin-top: 150px;
  max-width: var(--container-max);
  

  &__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 64px;
    @media (min-width: 760px) {
       grid-template-columns: 1fr 1fr 1fr;
    }
  }

    &__item {
    &__name {
      color: var(--color-dark);
      opacity: 0.7;
      margin: 1rem 0;
    }

    &__contact {
      font-size: var(--text-xl);
      display: block;
      margin-bottom: 0.5rem;
    }
  }

  &-title {
    font-size: var(--text-4xl);
    font-weight: bold;
    margin-bottom: 1.5rem;
    text-align: center;
    @media (min-width: 760px) {
        font-size: var(--text-5xl);
    }
  }

  &__map {
    border-radius: 24px;
    width: 100%;
    height: 400px;
    // filter: invert(100%) grayscale(100%) brightness(90%); // Убираем инверсию для светлой темы
    @media (min-width: 760px) {
       height: 600px;
    }
  }

}
</style>

<div class="contact-page">
  <h1 class="contact-page-title">Контакты</h1>
  <div class="contact-page__grid">
    <div class="contact-page__item">
      <div class="contact-page__item__name">
        Телефоны
      </div>
      <a href="tel:+78432121323" class="contact-page__item__contact">
        +7 (843) 212-13-23
      </a>
      <a href="tel:+78432533815" class="contact-page__item__contact">
        +7 (843) 253-38-15
      </a>
    </div>
    <div class="contact-page__item">
      <div class="contact-page__item__name">
        Почта
      </div>
      <a href="mail:info@nexcorehub.ru" class="contact-page__item__contact">
        info@nexcorehub.ru
      </a>
    </div>
    <div class="contact-page__item">
      <div class="contact-page__item__name">
        Адрес
      </div>
      <div class="contact-page__item__contact">
        Казань, ул. Проспект Ямашева, д. 115А
      </div>
    </div>

    
  </div>
  <iframe 
      class="contact-page__map" 
      src="https://yandex.ru/map-widget/v1/?um=constructor%3A5c2c1d1c55f40b5ed8cd008af8d018e85e9667b7e941431d2094f143c77b2181&amp;source=constructor" 
      
      frameborder="0">
    </iframe>
  
</div>