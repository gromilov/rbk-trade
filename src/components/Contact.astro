---
import db from "../lib/db";

const settingsRaw = db.prepare('SELECT * FROM settings').all();
const settings = Object.fromEntries(settingsRaw.map(s => [s.key, s.value]));

const { title = "Свяжитесь с нами" } = Astro.props;
---

<section class="contact-section" id="contact">
  <div class="contact-section__container">
    <div class="contact-section__card">
      <div class="contact-section__grid">
        <!-- Информация -->
        <div class="contact-section__info">
          <h2 class="contact-section__title">{title}</h2>
          
          <div class="contact-section__details">
            <div class="contact-section__detail">
              <span class="contact-section__label">Телефон</span>
              <a href={`tel:${settings.phone_1?.replace(/[^0-9+]/g, '')}`} class="contact-section__value">{settings.phone_1}</a>
            </div>
            <div class="contact-section__detail">
              <span class="contact-section__label">Почта</span>
              <a href={`mailto:${settings.email}`} class="contact-section__value">{settings.email}</a>
            </div>
          </div>

          <div class="contact-section__messengers">
            <span class="contact-section__label">Мессенджеры</span>
            <div class="contact-section__messenger-links">
              <a href={settings.telegram} target="_blank" class="contact-section__messenger-link">
                <svg width="22" height="18" viewBox="0 0 22 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M1.50257 7.76306C7.33266 5.20655 11.2298 3.55417 13.1939 2.74357C18.7434 0.436478 19.897 0.0311769 20.6452 0C20.8011 0 21.1752 0.0311772 21.4246 0.218239C21.6117 0.374123 21.674 0.592362 21.7052 0.748247C21.7364 0.904131 21.7676 1.24708 21.7364 1.52767C21.4246 4.67654 20.1464 12.3772 19.4605 15.9002C19.1799 17.3967 18.6187 17.8956 18.0887 17.9579C16.9352 18.0514 16.031 17.1785 14.9087 16.4614C13.1627 15.3079 12.1651 14.5908 10.4504 13.4684C8.48621 12.159 9.76446 11.4419 10.8868 10.2884C11.1674 9.97662 16.3116 5.33125 16.4051 4.89478C16.4051 4.83242 16.4363 4.64536 16.3116 4.55183C16.1869 4.4583 16.031 4.48948 15.9063 4.52065C15.7193 4.55183 12.9133 6.42245 7.45737 10.1013C6.64677 10.6625 5.9297 10.9119 5.27498 10.9119C4.55791 10.9119 3.18613 10.5066 2.15729 10.1637C0.910212 9.75838 -0.0874501 9.54014 0.00608066 8.85425C0.0684345 8.5113 0.567265 8.13718 1.50257 7.76306Z" fill="white"/>
                </svg>
                <span>Telegram</span>
              </a>
              <a href={settings.whatsapp} target="_blank" class="contact-section__messenger-link">
                <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M15.2464 26.3498C12.9962 26.3498 11.9505 26.0213 10.1328 24.7073C8.98304 26.1856 5.34221 27.3408 5.18342 25.3643C5.18342 23.8806 4.85492 22.6269 4.48262 21.2581C4.03916 19.5718 3.53546 17.6939 3.53546 14.9729C3.53546 8.47409 8.86808 3.58496 15.1862 3.58496C21.5097 3.58496 26.4646 8.71499 26.4646 15.0331C26.4858 21.2535 21.4667 26.3166 15.2464 26.3498ZM15.3395 9.20225C12.2626 9.04349 9.8645 11.1733 9.33344 14.513C8.89544 17.2778 9.67289 20.6449 10.3354 20.8201C10.6529 20.8968 11.4523 20.2507 11.9505 19.7525C12.7743 20.3216 13.7337 20.6634 14.7318 20.7435C17.92 20.8968 20.6442 18.4696 20.8582 15.285C20.9828 12.0935 18.5281 9.39038 15.3395 9.20774V9.20225Z" fill="white"/>
                </svg>
                <span>Max</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Форма -->
        <div class="contact-section__form">
          <form action="#" class="contact-form">
            <div class="contact-form__row">
              <div class="contact-form__group">
                <label for="name">Ваше имя</label>
                <input type="text" id="name" placeholder="Альберт" />
              </div>
              <div class="contact-form__group">
                <label for="phone">Номер телефона</label>
                <input type="tel" id="phone" placeholder="8 800 555 35 35" />
              </div>
            </div>
            
            <div class="contact-form__group">
              <label for="message">Расскажите о вашем проекте</label>
              <textarea id="message" rows="4"></textarea>
            </div>

            <div class="contact-form__checkbox">
              <input type="checkbox" id="privacy" checked />
              <label for="privacy">Я согласен с Политикой обработки персональных данных</label>
            </div>

            <button type="submit" class="contact-form__submit">Обсудить проект</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
.contact-section {
  padding: var(--space-20) 0;
  background-color: var(--color-white);

  &__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }

  &__card {
    background-color: #DE6D20;
    border-radius: 16px;
    padding: var(--space-10);
    color: white;

    @media (min-width: 1024px) {
      padding: 64px;
    }
  }

  &__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);

    @media (min-width: 1024px) {
      grid-template-columns: 1fr 1.15fr;
      gap: 56px;
    }
  }

  &__title {
    font-size: 32px;
    font-weight: var(--font-bold);
    margin-bottom: 48px;
    letter-spacing: -0.02em;
    line-height: var(--leading-tight);
    
    @media (min-width: 768px) {
      font-size: 56px;
    }
  }

  &__label {
    display: block;
    font-size: 14px;
    opacity: 0.8;
    margin-bottom: 12px;
  }

  &__value {
    display: block;
    font-size: 24px;
    font-weight: var(--font-medium);
    color: white;
    text-decoration: none;
    margin-bottom: 32px;

    &:hover {
      opacity: 0.8;
    }
  }

  &__details {
    margin-bottom: 48px;
    display: flex;
    flex-direction: column;

    @media (min-width: 768px) {
       flex-direction: row;
       gap: 64px;
    }
  }

  &__messenger-links {
    display: flex;
    gap: 40px;
  }

  &__messenger-link {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 24px;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.32);
    color: white;
    text-decoration: none;
  }

  // Стили формы
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;

    &__row {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;

      @media (min-width: 640px) {
        grid-template-columns: 1fr 1fr;
      }
    }

    &__group {
      display: flex;
      flex-direction: column;
      gap: 8px;

      label {
        font-size: 14px;
        opacity: 0.9;
      }

      input, textarea {
        background-color: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 8px;
        padding: 0 16px;
        height: 48px;
        color: white;
        font-family: inherit;
        font-size: 16px;

        &::placeholder {
          color: rgba(255, 255, 255, 0.5);
        }

        &:focus {
          outline: none;
          border-color: white;
        }
      }

      textarea {
        height: auto;
        padding: 12px 16px;
      }
    }

    &__checkbox {
      display: flex;
      gap: 12px;
      align-items: center;
      font-size: 14px;
      margin-top: 12px;

      input {
        width: 24px;
        height: 24px;
        background-color: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 4px;
        accent-color: white;
      }
    }

    &__submit {
      background-color: white;
      color: #DE6D20;
      border: none;
      border-radius: 28px;
      height: 56px;
      font-size: 16px;
      font-weight: var(--font-bold);
      cursor: pointer;
      margin-top: 24px;
      transition: background-color var(--transition-fast);

      &:hover {
        background-color: #f3f3f3;
      }
    }
  }
}
</style>