---
interface Props {
  title: string;
  subtitle?: string;
  image: string;
  link?: string;
}

const { title, subtitle, image, link = "#" } = Astro.props;
---

<a href={link} class="case-card">
  <div class="case-card__image-wrapper">
    <img src={image} alt={title} class="case-card__image" />
    <div class="case-card__overlay">
      <div class="case-card__header">
        <h3 class="case-card__title">{title}</h3>
        {subtitle && <p class="case-card__subtitle">{subtitle}</p>}
      </div>
      <div class="case-card__link-text">
        Подробнее 
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>
</a>

<style lang="scss">
  .case-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 592/384;
    cursor: pointer;
    display: block;
    text-decoration: none;

    &__image-wrapper {
      position: relative;
      width: 100%;
      height: 100%;
    }

    &__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }

    &:hover &__image {
      transform: scale(1.05);
    }

    &__overlay {
      position: absolute;
      inset: 0;
      padding: 32px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      background: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(8px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.4s ease;
    }

    &:hover &__overlay {
      opacity: 1;
      visibility: visible;
    }

    &__title {
      font-size: 20px;
      font-weight: 700;
      color: #FFFFFF;
      margin-bottom: 8px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    &__subtitle {
      font-size: 16px;
      color: #FFFFFF;
      opacity: 0.8;
      max-width: 400px;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    &__link-text {
      display: flex;
      align-items: center;
      gap: 8px;
      color: #FFFFFF;
      font-size: 16px;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 0.3s ease;
      
      &:hover {
        opacity: 0.8;
      }
      
      svg {
        transition: transform 0.3s ease;
      }
    }

    &:hover &__link-text svg {
      transform: translate(2px, -2px);
    }
  }
</style>
