---
const categories = [
  {
    title: "Дизайнерам интерьеров",
    text: "Батареи как элемент дизайна, а не просто инженерное решение. Помогаем подобрать модели, которые поддерживают концепцию интерьера и легко интегрируются в проект — с понятными характеристиками и аккуратным визуальным результатом.",
    link: "/services/designers",
    image: "/images/categories/designers.png"
  },
  {
    title: "Для частных домов и квартир",
    text: "Эстетичные и надёжные батареи для офисов, ресторанов, отелей и шоурумов. Решения, которые подчёркивают интерьер и стабильно работают в интенсивной эксплуатации.",
    link: "/services/residential",
    image: "/images/categories/residential.png"
  },
  {
    title: "Для коммерческих объектов",
    text: "Эстетичные и надёжные батареи для офисов, ресторанов, отелей и шоурумов. Решения, которые подчёркивают интерьер и стабильно работают в интенсивной эксплуатации.",
    link: "/services/commercial",
    image: "/images/categories/commercial.png"
  }
];
---

<section class="category-banners">
  <div class="category-banners__container">
    <div class="category-banners__grid">
      {categories.map((cat) => (
        <a href={cat.link} class="category-card">
          <div class="category-card__bg" style={`background-image: url(${cat.image})`}>
            <div class="category-card__overlay"></div>
          </div>
          <div class="category-card__content">
            <h3 class="category-card__title">{cat.title}</h3>
            <p class="category-card__text">{cat.text}</p>
            <div class="category-card__arrow">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  .category-banners {
    padding: var(--space-10) 0;
    
    &__container {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--space-4);
    }
    
    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
      
      @media (min-width: 1024px) {
        grid-template-columns: repeat(3, 1fr);
      }
    }
  }

  .category-card {
    position: relative;
    height: 400px;
    border-radius: 24px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding: 32px;
    text-decoration: none;
    transition: transform 0.3s ease;
    background-color: #f6f6f6; // Заглушка фона

    &:hover {
      transform: translateY(-8px);
    }

    &:hover &__arrow {
      transform: translateX(8px);
    }

    &__bg {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
    }

    &__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(17, 17, 17, 0.8) 0%, rgba(17, 17, 17, 0) 60%);
    }

    &__content {
      position: relative;
      z-index: 2;
      color: #fff;
    }

    &__title {
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 12px;
    }

    &__text {
      font-size: 16px;
      opacity: 0.8;
      margin-bottom: 24px;
      line-height: 1.4;
    }

    &__arrow {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.2);
      backdrop-filter: blur(8px);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.3s ease;
    }
  }
</style>
