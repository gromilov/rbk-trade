---
import Button from "./UI/Button.astro";

const categories = [
  {
    title: "Дизайнерам интерьеров",
    text: "Батареи как элемент дизайна, а не просто инженерное решение. Помогаем подобрать модели, которые поддерживают концепцию интерьера и легко интегрируются в проект — с понятными характеристиками и аккуратным визуальным результатом.",
    link: "/services/designers",
    image: "/images/categories/designers.png"
  },
  {
    title: "Для частных домов и квартир",
    text: "Эстетичные и надёжные батареи для офисов, ресторанов, отелей и шоурумов. Решения, которые подчёркивают интерьер и стабильно работают в интенсивной эксплуатации.",
    link: "/services/residential",
    image: "/images/categories/residential.png"
  },
  {
    title: "Для коммерческих объектов",
    text: "Эстетичные и надёжные батареи для офисов, ресторанов, отелей и шоурумов. Решения, которые подчёркивают интерьер и стабильно работают в интенсивной эксплуатации.",
    link: "/services/commercial",
    image: "/images/categories/commercial.png"
  }
];
---

<section class="category-banners">
  <div class="category-banners__container">
    <div class="category-banners__list">
      {categories.map((cat) => (
        <div class="category-banner">
          <div class="category-banner__bg" style={`background-image: url(${cat.image})`}>
            <div class="category-banner__overlay"></div>
          </div>
          <div class="category-banner__content">
            <h3 class="category-banner__title">{cat.title}</h3>
            <p class="category-banner__text">{cat.text}</p>
            <div class="category-banner__footer">
              <Button href={cat.link} variant="white" className="category-banner__btn">Подробнее</Button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss" is:global>
  .category-banners {
    padding: var(--space-10) 0;
    background-color: #fff;
    
    &__container {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--space-4);
    }
    
    &__list {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
  }

  .category-banner {
    position: relative;
    min-height: 480px;
    border-radius: 32px;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding: 60px;
    transition: transform 0.3s ease;

    @media (max-width: 768px) {
      padding: 40px 24px;
      min-height: 400px;
      align-items: flex-end;
    }

    &:hover {
      .category-banner__bg {
        transform: scale(1.02);
      }
    }

    &__bg {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      transition: transform 0.8s ease;
    }

    &__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.4) 50%, rgba(0, 0, 0, 0.2) 100%);

      @media (max-width: 768px) {
        background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.2) 100%);
      }
    }

    &__content {
      position: relative;
      z-index: 2;
      color: #fff;
      max-width: 640px;
    }

    &__title {
      font-size: clamp(32px, 5vw, 48px);
      font-weight: 700;
      margin-bottom: 24px;
      line-height: 1.1;
      color: #fff;
    }

    &__text {
      font-size: 18px;
      opacity: 0.9;
      margin-bottom: 40px;
      line-height: 1.5;
      color: #fff;

      @media (max-width: 768px) {
        font-size: 16px;
        margin-bottom: 32px;
      }
    }

    &__footer {
      display: flex;
    }

    &__btn {
      min-width: 160px;
      font-weight: 600;
    }
  }
</style>
